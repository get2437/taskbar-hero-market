# ---- Database (PostgreSQL) ----
POSTGRES_USER=taskbar
POSTGRES_PASSWORD=taskbar_secret
POSTGRES_DB=taskbar_hero
# docker compose 内ではホスト名 = サービス名 "db"
DATABASE_URL=postgresql://taskbar:taskbar_secret@db:5432/taskbar_hero?schema=public

# ---- Redis ----
REDIS_URL=redis://redis:6379

# ---- Steam Market ----
# 対象ゲームの appid (Taskbar Hero)
STEAM_APP_ID=3678970
# 価格を取得する通貨 (Steam currency code: 1=USD, 8=JPY, 16=KRW, 23=CNY)
STEAM_CURRENCY=8
# レート制限回避用のリクエスト間隔(ms)
STEAM_REQUEST_INTERVAL_MS=3500

# ---- App ----
# 自動更新間隔 (cron式 / 既定 15分毎)
MARKET_REFRESH_CRON=*/15 * * * *
# 管理画面用トークン
ADMIN_TOKEN=change_me_admin_token

# ---- リアルタイム (任意) ----
# 閲覧中アイテムの注文板を再取得する間隔(ms)
HOT_REFRESH_MS=20000

# ---- ステータス(説明文)取得 (任意) ----
# 説明文(基礎/固有/特殊ステータス・素材効果)は静的なので低頻度で更新 (既定 24時間 = 86400000ms)
DESC_REFRESH_MS=86400000
# true にすると worker 起動60秒後に1回だけ全件取得 (初回デプロイ用)
DESC_REFRESH_ON_START=false

# ---- 公開URL / SEO (任意) ----
NEXT_PUBLIC_SITE_URL=https://example.com
NEXT_PUBLIC_STEAM_APP_ID=3678970

# ---- アクセス解析 (任意・Plausible互換/Cookie不使用) ----
# 設定するとビルド時に解析スクリプトを埋め込む(再ビルド要)。未設定なら無効。
# 例: あなたのドメイン名。自前ホストなら NEXT_PUBLIC_PLAUSIBLE_SRC も指定。
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=
NEXT_PUBLIC_PLAUSIBLE_SRC=

# ---- 広告 (Google AdSense / 任意) ----
# マスタースイッチ (true で広告ON)。未設定/false なら全広告非表示。
# ※ サイト所有確認(meta タグ / ads.txt)は client さえあれば false でも機能する。
NEXT_PUBLIC_ADS_ENABLED=false
# 開発時に枠位置だけ確認したい場合 true (実広告は出ない)
NEXT_PUBLIC_ADS_PLACEHOLDER=false
# パブリッシャーID。未設定でもコード既定 (ca-pub-5326925561428482) が使われる。
NEXT_PUBLIC_ADSENSE_CLIENT=ca-pub-5326925561428482
# 配置別の広告ユニットID (未設定は DEFAULT にフォールバック)。まずは DEFAULT だけ設定すれば全枠で表示される。
NEXT_PUBLIC_AD_SLOT_DEFAULT=
NEXT_PUBLIC_AD_SLOT_HOME_TOP=
NEXT_PUBLIC_AD_SLOT_HOME_BOTTOM=
NEXT_PUBLIC_AD_SLOT_ITEMS_TOP=
NEXT_PUBLIC_AD_SLOT_ITEMS_BOTTOM=
NEXT_PUBLIC_AD_SLOT_DETAIL_CHART=
NEXT_PUBLIC_AD_SLOT_DETAIL_RELATED=
NEXT_PUBLIC_AD_SLOT_RANKINGS_TOP=
NEXT_PUBLIC_AD_SLOT_RANKINGS_BOTTOM=
NEXT_PUBLIC_AD_SLOT_GEAR_TOP=
NEXT_PUBLIC_AD_SLOT_GEAR_BOTTOM=
NEXT_PUBLIC_AD_SLOT_MATERIALS_TOP=
NEXT_PUBLIC_AD_SLOT_MATERIALS_BOTTOM=
NEXT_PUBLIC_AD_SLOT_SIDEBAR=
NEXT_PUBLIC_AD_SLOT_MOBILE=

# ---- ニュース自動翻訳 (任意) ----
# 設定すると Steam 公式ニュースの新着を Claude API で9言語へ自動翻訳して保存する。
# 未設定なら記事は英語原文のまま (翻訳ジョブは no-op)。
ANTHROPIC_API_KEY=

# ---- 監視 / エラー収集 (任意) ----
# 未設定なら構造化ログのみ (本番でも安全)。設定すると例外を送信する。
# Sentry を使う場合: プロジェクトの DSN (https://<key>@<host>/<projectId>)
SENTRY_DSN=
# Discord/Slack/汎用 への JSON POST 先 (Discord webhook URL をそのまま入れてOK)
MONITORING_WEBHOOK_URL=
# リリース識別子 (Sentry の release 表示用・任意)
APP_RELEASE=

# ---- Notifications (任意) ----
DISCORD_WEBHOOK_URL=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
NOTIFY_MAIL_FROM=
